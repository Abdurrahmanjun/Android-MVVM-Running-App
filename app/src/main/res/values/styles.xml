<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Momentum). -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/momentum_teal</item>
        <item name="colorPrimaryVariant">@color/momentum_ink</item>
        <item name="colorOnPrimary">@color/momentum_card</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/momentum_mint</item>
        <item name="colorSecondaryVariant">@color/momentum_teal</item>
        <item name="colorOnSecondary">@color/momentum_ink</item>
        <!-- App surfaces. -->
        <item name="android:windowBackground">@color/momentum_paper</item>
        <item name="colorSurface">@color/momentum_card</item>
        <item name="colorOnSurface">@color/momentum_ink</item>
        <!-- Light status bar (paper background, dark icons). -->
        <item name="android:statusBarColor">@color/momentum_paper</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>
</resources>
